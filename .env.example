# Environment: local | development | production
ENVIRONMENT=local

# Local SQLite (default). For Supabase Postgres, replace with the project connection string:
# DATABASE_URL=postgresql+psycopg://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=sqlite:///./data/housing_processor.db

# Supabase API — same project as DATABASE_URL when using hosted Postgres
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Settings → API → JWT Secret (server-only; used to verify access tokens)
SUPABASE_JWT_SECRET=your-jwt-secret

# Local SQLite smoke tests only. Ignored unless ENVIRONMENT=local and DATABASE_URL is SQLite.
AUTH_DISABLED=true

# local | s3 (s3 deferred)
STORAGE_BACKEND=local
STORAGE_ROOT=./data/storage

# LLM assisted extraction (Phase 2); keep disabled for Phase 1
LLM_ENABLED=false
LLM_PROVIDER=
LLM_MODEL=

# Matching thresholds (used when automatic matching is enabled)
AUTOMATIC_MATCH_THRESHOLD=100
REVIEW_MATCH_THRESHOLD=60

# Upload limits
MAX_UPLOAD_BYTES=10485760
